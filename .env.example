# Server
PORT=3000

# AWS credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Default Bedrock model ID (can be overridden per-request if in allowlist)
MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0

# Comma-separated list of valid API keys for this proxy
API_KEYS=dev1-key,dev2-key,prod-key

# Optional: set to "production" to suppress stack traces
NODE_ENV=development
